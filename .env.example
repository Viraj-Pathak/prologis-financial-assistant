# ─── Postgres ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=financial_assistant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ─── Google / Vertex AI ─────────────────────────────────────────────────────
# Get from https://aistudio.google.com/app/apikey (Vertex AI Express Mode)
GOOGLE_API_KEY=your_api_key_from_aistudio_google_com
GOOGLE_GENAI_USE_VERTEXAI=True

# ─── AWS ─────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-1

# SageMaker — set by deploy_sagemaker.py after deployment
SAGEMAKER_BUCKET=your-sagemaker-bucket
SAGEMAKER_ROLE_ARN=arn:aws:iam::123456789012:role/SageMakerExecutionRole
SAGEMAKER_REGRESSION_ENDPOINT=housing-rf-endpoint
SAGEMAKER_CLASSIFICATION_ENDPOINT=bank-lr-endpoint

# ─── DO NOT COMMIT THIS FILE ─────────────────────────────────────────────────
# Copy to .env and fill in real values. Never commit .env to version control.
